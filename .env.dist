# Winnow — configuration. Copier en `.env` puis adapter :
#   cp .env.dist .env
# Les valeurs par défaut visent le docker-compose fourni (noms de services
# postgres/redis comme hôtes). En production, change au minimum les identifiants.

# --- Base & file (hôtes = noms de services compose) ---
DATABASE_URL=postgres://winnow:winnow@postgres:5432/winnow
REDIS_URL=redis://redis:6379

# --- Stockage des dérivés ---
# disk (MVP) ou s3 (MinIO). Bascule sans changer le code.
STORAGE_DRIVER=disk
STORAGE_DISK_PATH=/data/derivatives
# Utilisés seulement si STORAGE_DRIVER=s3 :
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=winnow
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Exports (copie RAW pour Capture One) ---
EXPORT_DIR=/data/exports

# --- Ingest / import ---
# Inbox : tous les feeders (upload web, dépôt SMB, FTP, offload carte) y déposent.
INBOX_DIR=/data/inbox
# Incoming : archive permanente des originaux importés (zone RW du NAS).
INCOMING_DIR=/nas-incoming
IMPORT_CONCURRENCY=1
# Surveille l'inbox et importe automatiquement les nouveaux dépôts.
WATCH_INBOX=true

# --- Optiplex / Portainer (docker-compose-optiplex.yml) ---
# Domaine routé par Traefik (réseau `edge` externe).
DOMAIN_NAME=winnow.mondomaine.fr
# Ports HÔTE de pg/redis, décalés pour cohabiter avec une autre stack.
# (les ports CONTENEUR restent 5432/6379 ; mettre vide pour ne pas publier)
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380

# --- Montages NAS lus par docker-compose (chemins côté hôte Optiplex) ---
# Sessions déjà rangées (montées en lecture seule) :
NAS_MOUNT=/mnt/nas
# Zone d'arrivée des imports (montée en lecture/écriture) :
NAS_INCOMING=/mnt/nas/incoming

# --- Concurrence (ménager le HDD plein du NAS) ---
SCAN_CONCURRENCY=1
DERIVATIVE_CONCURRENCY=3
EXPORT_CONCURRENCY=2

# --- Tailles des dérivés ---
THUMB_SIZE=400
PROXY_SIZE=2048
THUMB_QUALITY=70
PROXY_QUALITY=80
