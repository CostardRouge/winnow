# Winnow — configuration. Copy to `.env` then adapt:
#   cp .env.dist .env
# The default values target the provided docker-compose (postgres/redis service
# names as hosts). In production, change at least the credentials.

# --- Database & queue (hosts = compose service names) ---
DATABASE_URL=postgres://winnow:winnow@postgres:5432/winnow
REDIS_URL=redis://redis:6379

# --- Derivative storage ---
# disk (MVP) or s3 (MinIO). Switch without changing the code.
STORAGE_DRIVER=disk
STORAGE_DISK_PATH=/data/derivatives
# Used only if STORAGE_DRIVER=s3:
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=winnow
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Exports (RAW copy for Capture One) ---
EXPORT_DIR=/data/exports

# --- Ingest / import ---
# Inbox: all feeders (web upload, SMB drop, FTP, card offload) drop here.
INBOX_DIR=/data/inbox
# Incoming: permanent archive of imported originals (RW zone of the NAS).
INCOMING_DIR=/nas-incoming
# Finals: "final" folder(s) of the NAS (Immich output). Indexed for
# browsing (thumbnails) but never culled/exported. Multiple paths possible,
# separated by a comma. Empty = no final folder.
FINALS_DIRS=/nas-final
IMPORT_CONCURRENCY=1
# Watches the inbox and automatically imports new drops.
WATCH_INBOX=true

# --- Optiplex / Portainer (docker-compose-optiplex.yml) ---
# Domain routed by Traefik (external `edge` network).
DOMAIN_NAME=winnow.example.com
# HOST ports for pg/redis, offset to coexist with another stack.
# (the CONTAINER ports stay 5432/6379; leave empty to not publish)
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
# MinIO (if the minio service is uncommented + STORAGE_DRIVER=s3). HOST ports
# offset to coexist with another MinIO stack; CONTAINER ports stay 9000/9001.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_HOST_PORT=9100
MINIO_CONSOLE_HOST_PORT=9101

# --- NAS mounts read by docker-compose (paths on the Optiplex host) ---
# Already-filed sessions (mounted read-only):
NAS_MOUNT=/mnt/nas
# Landing zone for imports (mounted read/write):
NAS_INCOMING=/mnt/nas/incoming
# "Final" folder of the NAS (Immich output), mounted read-only at /nas-final
# (must match FINALS_DIRS above):
NAS_FINAL=/mnt/nas/final

# --- Concurrency (spare the NAS's full HDD) ---
SCAN_CONCURRENCY=1
DERIVATIVE_CONCURRENCY=3
EXPORT_CONCURRENCY=2

# --- Derivative sizes ---
THUMB_SIZE=400
PROXY_SIZE=2048
THUMB_QUALITY=70
PROXY_QUALITY=80

# --- Video derivatives (ffmpeg) ---
# Hardware encoding acceleration: none = software (libx264, works everywhere).
# vaapi = Intel iGPU (share /dev/dri with the worker container; auto software fallback).
VIDEO_HWACCEL=none
VIDEO_VAAPI_DEVICE=/dev/dri/renderD128
# Height (px) and quality (CRF/QP, lower = better quality) of the mp4 proxy.
VIDEO_PROXY_HEIGHT=720
VIDEO_PROXY_CRF=24

# --- Observability ---
# Structured logs: level (debug|info|warn|error) and format (json|pretty).
# Defaults: info, and json when stdout is not a TTY (Docker), pretty on a dev TTY.
LOG_LEVEL=info
# LOG_FORMAT=json
# Prometheus metrics: the worker serves /metrics + /healthz on METRICS_PORT
# (the app also serves them at /api/metrics, reachable behind Traefik).
METRICS_ENABLED=true
METRICS_PORT=9091
