    "@types/heic-convert": "^1.2.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-window": "^1.8.8",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2"
