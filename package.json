  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/lib/migrate.ts",
    "worker": "tsx src/worker.ts",
    "scan": "tsx src/scripts/scan.ts",
    "geocode-backfill": "tsx src/scripts/geocode-backfill.ts",
    "ml-backfill": "tsx src/scripts/ml-backfill.ts",
    "srt-backfill": "tsx src/scripts/srt-backfill.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "bullmq": "^5.34.0",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "exiftool-vendored": "^28.6.0",
    "geist": "^1.7.2",
    "heic-convert": "^2.1.0",
    "ioredis": "^5.4.1",
    "leaflet": "^1.9.4",
    "next": "^15.1.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-window": "^1.8.11",
    "sharp": "^0.33.5",
