# --- Base & file ---
DATABASE_URL=postgres://winnow:winnow@postgres:5432/winnow
REDIS_URL=redis://redis:6379

# --- Stockage des dérivés ---
# disk (MVP) ou s3 (MinIO). Bascule sans changer le code.
STORAGE_DRIVER=disk
STORAGE_DISK_PATH=/data/derivatives
# Si STORAGE_DRIVER=s3 :
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=winnow
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Exports (copie RAW pour Capture One) ---
EXPORT_DIR=/data/exports

# --- Montage NAS (RO) lu par compose ---
NAS_MOUNT=/mnt/nas

# --- Concurrence (ménager le HDD plein du NAS) ---
SCAN_CONCURRENCY=1
DERIVATIVE_CONCURRENCY=3
EXPORT_CONCURRENCY=2

# --- Tailles des dérivés ---
THUMB_SIZE=400
PROXY_SIZE=2048
THUMB_QUALITY=70
PROXY_QUALITY=80
